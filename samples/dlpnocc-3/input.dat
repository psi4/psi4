#! comparison of DF-CCSD(T) and DLPNO-CCSD(T) CBS Extrapolation on Ar dimer
#! The reference DF-CCSD(T) values are stored and not rerun

memory 4 GB


molecule Ar2 {
0 1
Ar         0.00000000       0.00000000       0.00000000
--
0 1
Ar         0.00000000       0.00000000       3.75000000
units angstrom
symmetry c1
}

set freeze_core True
set scf_type df
set pno_convergence tight
set e_convergence 1.0e-8
set r_convergence 1.0e-8
set local_convergence 1.0e-11
set local_maxiter 10000
set dlpno_toggle_memory false

# Lower memory to ensure test runs with CI
set low_memory_overlap true
set write_qia_pno true
set write_qab_pno true
set write_triples_intermediates true
set write_triples_amplitudes false

print('   Computing DLPNO-CCSD(T)/cc-pV[TQ]Z interaction energy ...')
de_dlpno = energy('dlpno-ccsd(t)/cc-pV[TQ]Z', bsse_type='cp')
clean()
