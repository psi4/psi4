set basis def2-SVP
set freeze_core True
set scf_type df
set mp2_type df
set cc_type df
set nat_orbs False
set pno_convergence tight
set e_convergence 1.0e-8
set d_convergence 1.0e-8
set r_convergence 1.0e-8

if psi4.core.get_option("scf", "orbital_optimizer_package") == "INTERNAL":  # KP-TOL
    tol = 7
else:
    tol = 3e-7

print('   Testing DLPNO-CCSD(T) loose...')
set pno_convergence loose
val = energy('dlpno-ccsd(t)')

clean()

print('   Testing DLPNO-CCSD(T) normal...')
set pno_convergence normal
val = energy('dlpno-ccsd(t)')

clean()

print('   Testing DLPNO-CCSD(T) tight...')
set pno_convergence tight
val = energy('dlpno-ccsd(t)')

clean()

print('   Testing DLPNO-CCSD(T) very_tight...')
set pno_convergence very_tight
val = energy('dlpno-ccsd(t)')

clean()
