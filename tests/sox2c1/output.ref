--------------------------------------------------------------------------
#! Test of SOX2C-1e with Zn atom. Reference is from ReSpect (hf-1eX2C + ucc-pvdz).
ref_e = -1794.353979962273

molecule zn {
0 1
    Zn 0 0 0
symmetry C1
}

set {
  reference cghf
  scf_type pk
  basis cc-pvdz-decon
  basis_relativistic cc-pvdz-decon
  relativistic x2c
  spin_orbit_coupling true
  e_convergence 8
}

e_so = energy('scf')

compare_values(e_so, ref_e, 7, "SOX2C-1e total energy")
