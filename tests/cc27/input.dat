#! Single point gradient of 1-1B2 state of H2O with EOM-CCSD

molecule h2o {
  0 1
  H -0.107055195862289   0.000000000000000  -1.832806614599657
  O -0.107055195862289   0.000000000000000   0.094714436481352
  H  1.806098405595803   0.000000000000000   0.329620161376194
  units bohr
}

set {
  basis DZ
  roots_per_irrep [0, 0, 0, 1]
}

if psi4.core.get_option("scf", "orbital_optimizer_package") == "INTERNAL":  # KP-TOL
    findif5_tol = 7
else:
    # findif5_tol = 4e-7
    findif5_tol = 8e-7  # until sqrt fixed (only for ooo)

analytic_grad = gradient('eom-ccsd')
findif_grad = gradient('eom-ccsd', dertype=0)

compare_matrices(analytic_grad, findif_grad, 5, "RHF-EOM-CCSD finite-diff. (3-pt.) vs. analytic gradient to 10^-5") #TEST

set findif points 5

findif_grad = gradient('eom-ccsd', dertype=0)

compare_matrices(analytic_grad, findif_grad, findif5_tol, "RHF-EOM-CCSD finite-diff. (5-pt.) vs. analytic gradient to 10^-7") #TEST
