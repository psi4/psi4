#! Test fnocc with linear dependencies

molecule { 
o 
h 1 1.0 
h 1 1.0 2 104.5
}

set {
  basis 'aug-cc-pvtz'
  scf_type df
  cc_type df
  s_tolerance 1e-3
}

if psi4.core.get_option("scf", "orbital_optimizer_package") != "INTERNAL":  # KP-STOL-WEIRD
    psi4.set_options({"d_convergence": 5e-5})

set fnocc maxiter 50
energy = energy('ccsd')

compare_values(-76.344661646980, energy, 6, "CCSD Energy");                                       #TEST
