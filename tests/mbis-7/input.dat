#! MBIS regression test on CH3I with iodine

charges_ref = psi4.Matrix.from_list([ #TEST
 [-0.285761], 
 [-0.115352],
 [ 0.133773],
 [ 0.133667],
 [ 0.133667]])

dipoles_ref = psi4.Matrix.from_list([ #TEST
[ 0.000000,   -0.000025,    0.034895],
[-0.000000,    0.000012,   -0.055731], 
[ 0.000000,    0.057461,   -0.015360], 
[ 0.049682,   -0.028815,   -0.015398], 
[-0.049682,   -0.028815,   -0.015398]])

quadrupoles_ref = psi4.Matrix.from_list([ #TEST
[-4.6121, 0.0, 0.0, -4.6119, 0.0001           ,-4.5958],
[-20.8916, 0.0, 0.0, -20.8915, 0.00,-18.7655],
[-0.4354, 0.0, 0.0, -0.4269, 0.0019,-0.4408],
[-0.4291, -0.0037, 0.0017,   -0.4333,   -0.0010,   -0.4408],
[-0.4291,    0.0037,   -0.0017,   -0.4333,   -0.0010,   -0.4408]])

octupoles_ref = psi4.Matrix.from_list([ #TEST
[ 0.0           ,0.1653         , -0.0636,  0.0,              
  0.0           , 0.0           , -0.1656           , -0.0637,
  -0.0002           ,-0.5573],
[ 0.0           ,-0.0034 ,-0.6612, 0.0,             
  0.0           , 0.0           ,0.0035,
 -0.6614,0.0001,3.0096],
[ 0.0           , 0.0328 ,-0.0002, 0.0,          
  0.0           , 0.0           , 0.0613,
 0.0048, 0.0145,-0.0277],
[ 0.0610           , -0.0025 ,0.0035, 0.0203,          
  -0.0022           , 0.0125           , -0.0447,
 0.0010, -0.0073,-0.0278],

[ -0.0610           , -0.0025 ,0.0035, -0.0203,          
  0.0022           , -0.0125           , -0.0447,
 0.0010, -0.0073,-0.0278]])

avols_ref = psi4.Matrix.from_list([ # TEST
 [32.867407 ],
 [156.503921],
 [ 2.254043 ],
 [ 2.254056 ],
 [ 2.254057 ]])

vratios_ref = psi4.Matrix.from_list([
[1.000198],
[0.957253],
[0.308543],
[0.308544],
[0.308544]])

vwidths_ref = psi4.Matrix.from_list([ # TEST
[0.503045],
[0.697250],
[0.358590],
[0.358575],
[0.358575]])

vcharges_ref = psi4.Matrix.from_list([ # TEST
[-4.655022],
[-5.951511],
[-0.866227],
[-0.866333],
[-0.866333]])

molecule mol {
  0 1
  C 0.000000 0.000000 0.000000
  I 0.000000 0.000000 2.105000
  H 0.000000 0.937000 -0.297000
  H 0.811000 -0.469000 -0.297000
  H -0.811000 -0.469000 -0.297000
  symmetry c1
  no_reorient
  no_com
}

set {
  scf_type df
  d_convergence 8
  e_convergence 10
  mbis_radial_points 99
  mbis_spherical_points 350
  max_radial_moment 4
}
if psi4.core.get_option("scf", "orbital_optimizer_package") != "INTERNAL":  # KP-CONV
    psi4.set_options({"d_convergence": 3e-8})
set scf_properties ['MBIS_CHARGES', 'MBIS_VOLUME_RATIOS']

e, wfn = energy('hf/def2-SVP', return_wfn=True)

charges = wfn.array_variable('MBIS CHARGES').to_array()
dipoles = wfn.array_variable('MBIS DIPOLES')
quadrupoles = wfn.array_variable('MBIS QUADRUPOLES')
octupoles = wfn.array_variable('MBIS OCTUPOLES')
avols = wfn.array_variable('MBIS RADIAL MOMENTS <R^3>').to_array()
vwidths = wfn.array_variable('MBIS VALENCE WIDTHS').to_array()
vcharges = wfn.array_variable('MBIS VALENCE CHARGES').to_array()
vratios = wfn.array_variable('MBIS VOLUME RATIOS').to_array()

compare_values(0.0, np.sum(charges), 5, "CH3I MBIS total charge")  #TEST
compare_matrices(dipoles_ref, dipoles, 5, "MBIS Dipoles")             #TEST
compare_matrices(quadrupoles_ref, quadrupoles, 5, "MBIS Quadrupoles") #TEST
compare_matrices(octupoles_ref, octupoles, 5, "MBIS Octupoles")       #TEST
compare_matrices(avols_ref, avols, 5, "MBIS Radial Moments <r^3>")    #TEST
compare_matrices(vwidths_ref, vwidths, 5, "MBIS Valence Widths")      #TEST
compare_matrices(vcharges_ref, vcharges, 5, "MBIS Valence Charges")   #TEST
compare_matrices(vratios_ref, vratios, 5, "MBIS Volume Ratios")      #TEST
