#! pcm pure-am sentinel

nucenergy = 12.0367196636183458 #TEST
polenergy = -0.006800356943689 #TEST
totalenergy = -56.200478109909199 #TEST
rohf_polenergy = -0.006800513873662 #TEST
rohf_totalenergy = -56.200478109588893 #TEST

molecule NH3 {
N     -0.0000000001    -0.1040380466      0.0000000000
H     -0.9015844116     0.4818470201     -1.5615900098
H     -0.9015844116     0.4818470201      1.5615900098
H      1.8031688251     0.4818470204      0.0000000000
units bohr
}

set {
  basis cc-pVDZ
  scf_type pk
  pcm true
  pcm_scf_type total
}

pcm = {
   Units = Angstrom
   Medium {
   SolverType = IEFPCM
   Solvent = Water
   }

   Cavity {
   RadiiSet = UFF
   Type = GePol
   Scaling = False
   Area = 0.3
   Mode = Implicit
   }
}

print_out('PK-RHF-PCM, total algorithm')
energy_scf, wfn = energy('scf', return_wfn=True)
compare_values(nucenergy, NH3.nuclear_repulsion_energy(), 10, "Nuclear repulsion energy (PCM, total algorithm)") #TEST
compare_values(totalenergy, energy_scf, 10, "Total energy (PCM, total algorithm)") #TEST
compare_values(polenergy, wfn.variable("PCM POLARIZATION ENERGY"), 6, "Polarization energy (PCM, total algorithm)") #TEST

set pcm_scf_type separate
print_out('PK-RHF-PCM, separate algorithm')
energy_scf, wfn = energy('scf', return_wfn=True)
compare_values(totalenergy, energy_scf, 10, "Total energy (PCM, separate algorithm)") #TEST
compare_values(polenergy, wfn.variable("PCM POLARIZATION ENERGY"), 6, "Polarization energy (PCM, separate algorithm)") #TEST

set pcm_scf_type total
set reference uhf
print_out('PK-UHF-PCM, total algorithm')
energy_scf, wfn = energy('scf', return_wfn=True)
compare_values(totalenergy, energy_scf, 10, "Total energy (PCM, total algorithm, UHF)") #TEST
compare_values(polenergy, wfn.variable("PCM POLARIZATION ENERGY"), 6, "Polarization energy (PCM, total algorithm, UHF)") #TEST

set reference rohf
print_out('PK-ROHF-PCM, total algorithm')
energy_scf, wfn = energy('scf', return_wfn=True)
compare_values(rohf_totalenergy, energy_scf, 10, "Total energy (PCM, total algorithm, ROHF)") #TEST
compare_values(rohf_polenergy, wfn.variable("PCM POLARIZATION ENERGY"), 6, "Polarization energy (PCM, total algorithm, ROHF)") #TEST
